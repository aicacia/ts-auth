{
	"name": "auth",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"tauri": "tauri",
		"vite": "vite",
		"svelte-kit": "svelte-kit",
		"clean": "rm -rf node_modules/.vite .svelte-kit build",
		"start": "npm run web",
		"web": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"desktop": "tauri dev",
		"desktop:build": "tauri build",
		"android": "tauri android dev --open",
		"android:build": "tauri android build",
		"ios": "tauri ios dev --open",
		"ios:build": "tauri ios build",
		"openapi": "rm -rf src/lib/openapi/auth && openapi-generator-cli generate -i http://localhost:8080/api-docs/openapi.json -g typescript-fetch -o 'src/lib/openapi/auth' --type-mappings=DateTime=Date --additional-properties=modelPropertyNaming=snake_case,supportsES6=true,withInterfaces=true,useSingleRequestParameter=false",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. ."
	},
	"devDependencies": {
		"@openapitools/openapi-generator-cli": "2",
		"@sveltejs/adapter-static": "2",
		"@sveltejs/kit": "1",
		"@tauri-apps/api": "2.0.0-alpha.12",
		"@tauri-apps/cli": "2.0.0-alpha.18",
		"@types/postcss-import": "14",
		"@typescript-eslint/eslint-plugin": "6",
		"@typescript-eslint/parser": "6",
		"autoprefixer": "10",
		"eslint": "8",
		"eslint-config-prettier": "9",
		"eslint-plugin-svelte": "2",
		"postcss": "8",
		"postcss-import": "15",
		"postcss-nesting": "12",
		"prettier": "3",
		"prettier-plugin-svelte": "3",
		"svelte-check": "3",
		"tailwindcss": "3",
		"tslib": "2",
		"typescript": "5",
		"vite": "4"
	},
	"dependencies": {
		"@aicacia/debounce": "0",
		"@aicacia/rand": "0",
		"@aicacia/string-fuzzy_equals": "0",
		"@svelte-put/clickoutside": "3",
		"eventemitter3": "5",
		"js-base64": "3",
		"lucide-svelte": "0.269.0",
		"svelte": "4",
		"svelte-localstorage-writable": "0",
		"svelte-portal": "2",
		"vest": "4"
	}
}
